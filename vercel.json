{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "style.css",
          "script.js",
          "index.html",
          "images/**",
          "admin/**/*.html",
          "admin/**/*.css",
          "admin/**/*.js"
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ]
}